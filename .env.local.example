# Claude API — use Haiku for cost efficiency
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Unsplash for story images (free tier: 50 req/hr)
UNSPLASH_ACCESS_KEY=

# Optional: NewsAPI for broader coverage (free tier: 100 req/day)
# Start without this — RSS feeds are free and sufficient
NEWS_API_KEY=

# Cache TTL in seconds (default: 1800 = 30 min)
# Keep high to minimize Claude calls = lower cost
CACHE_TTL_SECONDS=1800
